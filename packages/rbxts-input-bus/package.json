{
  "name": "@trembus/rbxts-input-bus",
  "version": "0.1.0",
  "description": "Multi-device input bus for roblox-ts with context switching (KBM, Gamepad, Touch)",
  "license": "MIT",
  "author": "trembus",
  "main": "out/init.luau",
  "types": "out/index.d.ts",
  "files": [
    "out",
    "!**/*.tsbuildinfo",
    "flamework.build",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nicholasosto/rbxts-package",
    "directory": "packages/rbxts-input-bus"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rbxtsc",
    "watch": "rbxtsc -w",
    "clean": "rm -rf out include",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "roblox",
    "typescript",
    "input",
    "rbxts",
    "keyboard",
    "gamepad",
    "touch",
    "event-bus",
    "input-system"
  ],
  "peerDependencies": {
    "@flamework/core": "^1.3.2",
    "@rbxts/services": "^1.6.0",
    "@rbxts/signal": "^1.1.1"
  },
  "peerDependenciesMeta": {
    "@flamework/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rbxts/compiler-types": "3.0.0-types.0",
    "@rbxts/services": "^1.6.0",
    "@rbxts/signal": "^1.1.1",
    "@rbxts/types": "^1.0.879",
    "@flamework/core": "^1.3.2",
    "rbxts-transformer-flamework": "^1.3.2",
    "roblox-ts": "^3.0.0",
    "typescript": "^5.5.3"
  }
}
